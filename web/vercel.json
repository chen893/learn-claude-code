{
  "redirects": [
    {
      "source": "/:locale(en|zh|ja)/:version(s01|s02|s03|s04|s05|s06|s07|s08|s09|s10|s11|s12)/diff/",
      "destination": "/:locale/python/:version/diff",
      "permanent": true
    },
    {
      "source": "/:locale(en|zh|ja)/:version(s01|s02|s03|s04|s05|s06|s07|s08|s09|s10|s11|s12)/diff",
      "destination": "/:locale/python/:version/diff",
      "permanent": true
    },
    {
      "source": "/:locale(en|zh|ja)/:version(s01|s02|s03|s04|s05|s06|s07|s08|s09|s10|s11|s12)/",
      "destination": "/:locale/python/:version",
      "permanent": true
    },
    {
      "source": "/:locale(en|zh|ja)/:version(s01|s02|s03|s04|s05|s06|s07|s08|s09|s10|s11|s12)",
      "destination": "/:locale/python/:version",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "learn-claude-agents.vercel.app"
        }
      ],
      "destination": "https://learn.shareai.run/:path",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/en",
      "permanent": false
    }
  ]
}
